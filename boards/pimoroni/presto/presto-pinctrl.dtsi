/*
 * SPDX-License-Identifier: MIT
 *
 * Pin function selection for the Pimoroni Presto (RP2350B QFN-80).
 *
 * Pin assignments derived from the official Presto schematic and from
 * pimoroni/presto:boards/presto/presto.h.
 */

#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2350b-pinctrl.h>

&pinctrl {
	/*
	 * UART0 sits on GP0/GP1. The display also uses these pins as
	 * blue data lanes (B7/B6) when the panel is brought up. With the
	 * display node disabled (current state of this port) UART0 is the
	 * console; if the display is ever enabled, the lines collide.
	 */
	uart0_default: uart0_default {
		group1 {
			pinmux = <UART0_TX_P0>;
		};
		group2 {
			pinmux = <UART0_RX_P1>;
			input-enable;
		};
	};

	/* I2C0: Qw/ST connector (SDA=GP40, SCL=GP41). */
	i2c0_default: i2c0_default {
		group1 {
			pinmux = <I2C0_SDA_P40>, <I2C0_SCL_P41>;
			input-enable;
			input-schmitt-enable;
		};
	};

	/* I2C1: FT6236 capacitive touch (SDA=GP30, SCL=GP31). */
	i2c1_default: i2c1_default {
		group1 {
			pinmux = <I2C1_SDA_P30>, <I2C1_SCL_P31>;
			input-enable;
			input-schmitt-enable;
		};
	};

	/* PIO0-SPI CLK for the CYW43439 PIO-SPI controller. */
	pio0_spi0_default: pio0_spi0_default {
		group1 {
			pinmux = <PIO0_P29>;
		};
	};

	/* CYW43439 data line is bidirectional and bus-selected via PIO0. */
	airoc_wifi_default: airoc_wifi_default {
		group1 {
			pinmux = <PIO0_P24>;
			input-enable;
		};
	};

	/* Same line in GPIO mode for host-wake IRQ. */
	airoc_wifi_host_wake: airoc_wifi_host_wake {
		group1 {
			pinmux = <GPIO_P24>;
			input-enable;
		};
	};

	/* WS2812 (7x SK6812) chain data on GP33, driven by PIO0 SM3. */
	ws2812_pio0_default: ws2812_pio0_default {
		group1 {
			pinmux = <PIO0_P33>;
		};
	};
};
